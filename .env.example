# Copy this file to .env (same folder as server.py) and fill in your real
# OpenRouter key. Never paste your real key into a chat with any AI tool -
# fill this in yourself, locally.
OPENROUTER_API_KEY=

# Comma-separated OpenRouter model IDs for the council members.
# Default if left empty: openai/gpt-5.1,anthropic/claude-sonnet-4.5,google/gemini-3-pro-preview
COUNCIL_MODELS=openai/gpt-5.1,anthropic/claude-sonnet-4.5,google/gemini-3-pro-preview

# Chairman model that synthesizes the final answer from stage 1 + stage 2.
# Default if left empty: google/gemini-3-pro-preview
CHAIRMAN_MODEL=google/gemini-3-pro-preview
